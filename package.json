{
  "name": "@dr.pogodin/babel-plugin-add-import-extension",
  "version": "2.0.0",
  "description": "A babel plugin to add extension on project modules imports",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/birdofpreyru"
  },
  "main": "build/plugin.js",
  "scripts": {
    "build": "rimraf build && node node_modules/.bin/babel src --out-dir build -x .ts",
    "jest": "jest",
    "lint": "eslint --cache",
    "test": "npm run lint && npm run typecheck && npm run jest",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/birdofpreyru/babel-plugin-add-import-extension.git"
  },
  "keywords": [
    "babel",
    "plugin",
    "import",
    "export",
    "transform",
    "extension"
  ],
  "author": "Dr. Sergey Pogodin <doc@pogodin.studio> (https://dr.pogodin.studio)",
  "homepage": "https://dr.pogodin.studio/docs/babel-plugin-add-import-extension",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/birdofpreyru/babel-plugin-add-import-extension/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "peerDependencies": {
    "@babel/core": "^8.0.1"
  },
  "devDependencies": {
    "@babel/cli": "^8.0.1",
    "@babel/core": "^8.0.1",
    "@babel/plugin-syntax-typescript": "^8.0.3",
    "@babel/preset-env": "^8.0.2",
    "@babel/preset-typescript": "^8.0.1",
    "@dr.pogodin/eslint-configs": "^0.3.0-alpha.3",
    "@jest/globals": "^30.4.1",
    "@tsconfig/recommended": "^1.0.13",
    "@types/node": "^24.13.2",
    "babel-plugin-transform-import-meta": "^3.0.0",
    "jest": "^30.4.2",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@babel/types": "^8.0.0"
  }
}
