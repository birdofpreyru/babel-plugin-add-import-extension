{
  "name": "@dr.pogodin/babel-plugin-add-import-extension",
  "version": "2.3.3",
  "description": "A babel plugin to add extension on project modules imports",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/birdofpreyru"
  },
  "main": "build/plugin.js",
  "exports": {
    "types": "./build/plugin.d.ts",
    "default": "./build/plugin.js"
  },
  "scripts": {
    "build": "rimraf build && npm run build:types && npm run build:logic",
    "build:logic": "node node_modules/.bin/babel src --out-dir build -x .ts",
    "build:types": "tsc --project tsconfig.types.json",
    "jest": "NODE_OPTIONS=\"$NODE_OPTIONS --experimental-vm-modules\" jest",
    "lint": "eslint --cache",
    "test": "npm run lint && npm run typecheck && npm run jest",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/birdofpreyru/babel-plugin-add-import-extension.git"
  },
  "keywords": [
    "babel",
    "plugin",
    "import",
    "export",
    "transform",
    "extension"
  ],
  "author": "Dr. Sergey Pogodin <doc@pogodin.studio> (https://dr.pogodin.studio)",
  "homepage": "https://dr.pogodin.studio/docs/babel-plugin-add-import-extension",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/birdofpreyru/babel-plugin-add-import-extension/issues"
  },
  "engines": {
    "node": ">=24"
  },
  "peerDependencies": {
    "@babel/core": "^8.0.1"
  },
  "devDependencies": {
    "@babel/cli": "^8.0.4",
    "@babel/core": "^8.0.1",
    "@babel/plugin-syntax-typescript": "^8.0.3",
    "@babel/preset-env": "^8.0.2",
    "@babel/preset-typescript": "^8.0.1",
    "@dr.pogodin/eslint-configs": "^0.3.1",
    "@jest/globals": "^30.4.1",
    "@tsconfig/recommended": "^1.0.13",
    "@types/node": "^24.13.3",
    "jest": "^30.4.2",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@babel/types": "^8.0.4"
  },
  "type": "module"
}
