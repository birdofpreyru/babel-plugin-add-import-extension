{
  "$schema": "https://json.schemastore.org/tsconfig",
  "include": ["src"],
  "extends": "@tsconfig/recommended/tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "emitDeclarationOnly": true,
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noUncheckedIndexedAccess": true,
    "outDir": "build",
    "rootDir": "./src",
    "types": ["node"],
    "verbatimModuleSyntax": true
  }
}
